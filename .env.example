# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Auth
JWT_SECRET=your_jwt_secret_base64
JWT_REFRESH_SECRET=your_jwt_refresh_secret_base64

# Payments — Paystack
PAYSTACK_SECRET_KEY=sk_live_...
PAYSTACK_PUBLIC_KEY=pk_live_...
PLATFORM_COMMISSION_RATE=0.3
PLATFORM_FEE_PERCENT=5
PAYSTACK_TRANSFER_FEE_KOBO=5000

# Payments — PayPal (optional)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_PRESET=ml_default

# Email (Resend)
RESEND_API_KEY=re_...
SENDER_EMAIL=notifications@yourdomain.com

# AI
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=
GROK_API_KEY=

# WebSockets (Soketi)
SOKETI_APP_ID=
SOKETI_KEY=
SOKETI_SECRET=
SOKETI_HOST=
SOKETI_PORT=443
SOKETI_USE_TLS=true

# Redis — Upstash (REST, for rate limiting/cache)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Redis — BullMQ (TCP, for job queues)
QUEUE_REDIS_URL=redis://default:password@host:port

# Shipping — Sendbox
SENDBOX_ACCESS_TOKEN=
SENDBOX_CLIENT_SECRET=
SENDBOX_WEBHOOK_SECRET=

# Shipping — Shippo
SHIPPO_API_KEY=shippo_live_...
SHIPPO_WEBHOOK_SECRET=

# OAuth
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=
OAUTH_TIKTOK_CLIENT_KEY=
OAUTH_TIKTOK_CLIENT_SECRET=

# Media
JAMENDO_CLIENT_ID=
UNSPLASH_ACCESS_KEY=

# Public / runtime
NUXT_PUBLIC_BASE_URL=https://yourdomain.com
NUXT_PUBLIC_SITE_NAME=MarketX
NUXT_PUBLIC_BRAND_DOMAIN=yourdomain.com
NUXT_PUBLIC_SUPPORT_EMAIL=support@yourdomain.com

# Security flags
REQUIRE_EMAIL_VERIFICATION=true
ENABLE_2FA=false

# Rate limiting (milliseconds)
RATE_LIMIT_REGISTER_MAX=3
RATE_LIMIT_REGISTER_WINDOW=3600000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_LOGIN_WINDOW=900000
RATE_LIMIT_LOGIN_ATTEMPTS=5
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_LOCKOUT_MS=1800000
RATE_LIMIT_FORGOT_PASSWORD_MAX=3
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=3600000
RATE_LIMIT_VERIFY_EMAIL_SEND_MAX=5
RATE_LIMIT_VERIFY_EMAIL_SEND_WINDOW=900000
RATE_LIMIT_VERIFY_EMAIL_TOKEN_MAX=5
RATE_LIMIT_VERIFY_EMAIL_TOKEN_WINDOW=900000
RATE_LIMIT_REFRESH_TOKEN_MAX=10
RATE_LIMIT_REFRESH_TOKEN_WINDOW=300000

# Logging service (optional external sink)
LOG_SERVICE_URL=
LOG_SERVICE_TOKEN=
